{
  "expo": {
    "name": "Parchment",
    "slug": "parchment",
    "version": "0.4.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "parchment",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.parchment.ios",
      "supportsTablet": false,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.parchment.android",
      "adaptiveIcon": {
        "backgroundColor": "#cc9740",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#190901",
          "image": "./assets/images/picon.png",
          "imageWidth": 120,
          "android": {
            "backgroundColor": "#190901",
            "image": "./assets/images/picon.png",
            "imageWidth": 120
          },
          "ios": {
            "backgroundColor": "#190901",
            "image": "./assets/images/picon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Parchment needs photo library access to attach cover images to decks and image content to cards.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b22e96f9-f836-4b0f-94aa-5dfe5a8b7be2"
      }
    },
    "owner": "thewanderer313"
  }
}
